# Homebrew formula for {{PROJECT_NAME}}. Installs the prebuilt binary for the
# current platform from {{PROJECT_NAME}}'s GitHub Releases — no Go toolchain
# needed. `brew install --HEAD` builds (pure Go) from source instead.
#
#   brew install {{GITHUB_USER}}/tap/{{PROJECT_NAME}}
#
# This file is generated by {{PROJECT_NAME}}'s release.yml from
# .github/formula/{{PROJECT_NAME}}.rb.tmpl on every stable tag — edit the template
# there, not the tap copy. The release job fills __VERSION__ with the v-stripped
# release version and the four __SHA_*__ tokens with the archive checksums from
# dist/checksums.txt.
class {{FORMULA_CLASS}} < Formula
  desc "{{DESCRIPTION}}"
  homepage "{{REPO_URL}}"
  version "__VERSION__"
{{#HAS_LICENSE}}
  license "{{LICENSE_ID}}"
{{/HAS_LICENSE}}

  livecheck do
    url :stable
    strategy :github_latest
  end

  head do
    url "{{REPO_URL}}.git", branch: "main"
    depends_on "go" => :build
  end

  # Add runtime dependencies here. For a tool a release binary shells out to at
  # runtime, add a depends_on line, e.g. for ast-grep:  depends_on "ast-grep"

  on_macos do
    on_arm do
      url "{{REPO_URL}}/releases/download/v#{version}/{{PROJECT_NAME}}_#{version}_darwin_arm64.tar.gz"
      sha256 "__SHA_DARWIN_ARM64__"
    end
    on_intel do
      url "{{REPO_URL}}/releases/download/v#{version}/{{PROJECT_NAME}}_#{version}_darwin_amd64.tar.gz"
      sha256 "__SHA_DARWIN_AMD64__"
    end
  end

  on_linux do
    on_arm do
      url "{{REPO_URL}}/releases/download/v#{version}/{{PROJECT_NAME}}_#{version}_linux_arm64.tar.gz"
      sha256 "__SHA_LINUX_ARM64__"
    end
    on_intel do
      url "{{REPO_URL}}/releases/download/v#{version}/{{PROJECT_NAME}}_#{version}_linux_amd64.tar.gz"
      sha256 "__SHA_LINUX_AMD64__"
    end
  end

  def install
    if build.head?
      ENV["CGO_ENABLED"] = "0"
      ldflags = "-s -w -X {{MODULE_PATH}}/internal/version.Version=#{version}"
      system "go", "build", *std_go_args(ldflags: ldflags, output: bin/"{{PROJECT_NAME}}"), "./cmd/{{PROJECT_NAME}}"
    else
      # brew auto-extracts the release tarball; install the bare binary.
      bin.install "{{PROJECT_NAME}}"
    end
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/{{PROJECT_NAME}} --version")
  end
end
