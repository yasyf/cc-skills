{
  "setup": [
    "cp -R $SUPERSET_ROOT_PATH/.env*",
    "echo 'DEBUG=1' >> .env",
    "direnv allow",
    "uv sync --extra dev --inexact",
    "jj git init --git-repo .",
    "jj config set --user user.name \"{{AUTHOR_NAME}}\"",
    "jj config set --user user.email \"{{AUTHOR_EMAIL}}\""
  ],
  "teardown": [],
  "run": []
}
