#!/usr/bin/env bash
# ab — run agent-browser against ONE persistent Browserbase session per caller,
# reconnecting to it across invocations so a multi-step flow shares a live page.
#
#   • default            → Browserbase, reconnecting to this caller's keepAlive session
#   • --local (anywhere) → local browser (flag stripped before hand-off)
#   • --bridge (anywhere)→ local cookiesync CDP bridge: a throwaway pre-seeded Chrome
#                          whose ws:// endpoint agent-browser connects to; optional
#                          --bridge=<host:browser:profile> target (else chrome:Default)
#   • --session <name>   → suffix the caller identity (AB_SESSION env works too; the
#                          flag wins): parallel agents in one Claude Code session each
#                          get their own browser session
#   • key unresolvable   → warn on stderr, fall back to local
#   • ab mode            → print "bridge", "browserbase", or "local" (no session side effects)
#   • ab close           → release this caller's Browserbase session (or stop the bridge)
#
# The session is keyed by `cookiesync requestor` (stable per agent session), tagged in
# Browserbase's own registry (no local state), created with keepAlive, and released on
# close. The API key is fed to curl over stdin so it never lands in argv; the session's
# connectUrl still passes as `agent-browser connect` argv (no stdin form exists upstream)
# — it is a short-lived per-session credential, released on close. Assumes sequential
# invocation per caller (the skill drives it one command at a time).
#
# Contract: --local, --bridge[=target], and --session <name> anywhere in argv are always
# consumed as ab's own flags (--session also consumes the token after it), so a literal
# can never pass through as data (e.g. a storage value) — quoteless by design.
#
# Key: op://OpenClaw/BROWSERBASE_API_KEY/notesPlain.
set -uo pipefail

BB_API="https://api.browserbase.com/v1"
SESSION_TIMEOUT=1800 # seconds; a keepAlive session self-expires if `close` never runs

# Stable per-caller identity; --session/AB_SESSION (below) suffixes it, and the
# name-safe slug for the Browserbase tag and local agent-browser session name derives
# after flag parsing.
TAG="$(cookiesync requestor)" || {
  echo "ab: 'cookiesync requestor' failed — cannot derive a session identity" >&2
  exit 1
}

# Strip our own --local / --session <name>; pass everything else through. `close` is
# our subcommand only when it leads.
force_local=0
use_bridge=0
bridge_target=()
session=""
want_session=0
args=()
for a in "$@"; do
  if [[ "$want_session" == 1 ]]; then
    [[ -n "$a" ]] || {
      echo "ab: --session needs a value" >&2
      exit 2
    }
    session="$a"
    want_session=0
    continue
  fi
  case "$a" in
  --local) force_local=1 ;;
  --bridge) use_bridge=1 ;;
  --bridge=*)
    use_bridge=1
    [[ "$a" == "--bridge=" ]] || bridge_target=("${a#--bridge=}")
    ;;
  --session) want_session=1 ;;
  *) args+=("$a") ;;
  esac
done
[[ "$want_session" == 0 ]] || {
  echo "ab: --session needs a value" >&2
  exit 2
}

# The override suffixes (never replaces) the requestor identity, so the same short
# name in two Claude Code sessions still means two Browserbase sessions.
session="${session:-${AB_SESSION:-}}"
[[ -z "$session" ]] || TAG="$TAG · $session"
# Outside a recognized Claude session `cookiesync requestor` falls back to the parent PID, so cross-invocation persistence is defeated there (documented limitation, not fixed here).
# The sanitizer is non-injective (`a/b` and `a?b` both fold to `a-b`), so append a short stable hash of the FULL raw TAG to keep distinct requestors on distinct sessions.
SLUG="ab-$(printf '%s' "$TAG" | tr -C 'A-Za-z0-9' '-' | tr -s '-' | sed 's/^-//; s/-$//')-$(printf '%s' "$TAG" | shasum -a 256 | cut -c1-8)"
API_KEY="${BROWSERBASE_API_KEY:-$(op read 'op://OpenClaw/BROWSERBASE_API_KEY/notesPlain' 2>/dev/null || true)}"

# `mode` — report which backend a call would use (the key resolution + --local logic
# above, nothing else) so helpers like abwc-seed never duplicate it.
if [[ "${args[0]:-}" == "mode" ]]; then
  if [[ "$use_bridge" == 1 ]]; then
    echo bridge
  elif [[ "$force_local" == 1 || -z "$API_KEY" ]]; then
    echo local
  else
    echo browserbase
  fi
  exit 0
fi

is_close=0
[[ "${args[0]:-}" == "close" ]] && is_close=1

run() { exec agent-browser --session "$SLUG" ${args[@]+"${args[@]}"}; }
daemon_has_session() { agent-browser session list 2>/dev/null | sed 's/^[[:space:]]*//' | grep -Fqx -- "$SLUG"; }

# --bridge — route agent-browser through a local cookiesync CDP bridge: a throwaway
# Chrome pre-seeded with the caller's cookies, exposed over a token-scoped ws:// CDP
# endpoint. `cookiesync bridge open --json` launches (or reuses) it and prints the
# endpoint; agent-browser connects to that FULL tokened URL (never a bare port — the
# path token is required). The bridge is its own backend, so it precedes the --local /
# Browserbase resolution below and never touches BROWSERBASE_API_KEY.
if [[ "$use_bridge" == 1 ]]; then
  # Stop this caller's bridge, returning cookiesync's own exit status so callers can
  # surface a real failure instead of leaving a bridge live silently.
  bridge_stop() { cookiesync bridge stop ${bridge_target[@]+"${bridge_target[@]}"} >/dev/null 2>&1; }

  if [[ "$is_close" == 1 ]]; then
    agent-browser --session "$SLUG" close >/dev/null 2>&1 || true
    bridge_stop || {
      echo "ab: 'cookiesync bridge stop' failed — the bridge may still be live" >&2
      exit 1
    }
    exit 0
  fi

  # Stop the bridge if we fail before handing off. exec (a successful hand-off) replaces
  # the shell, so the EXIT trap never fires on success — the bridge persists for reuse
  # across calls. INT/TERM stop then exit signal-correct; the handler clears EXIT first
  # so the stop runs exactly once. bridge_armed gates the stop to a session we opened.
  bridge_armed=0
  on_bridge_exit() {
    [[ "$bridge_armed" == 0 ]] && return 0
    bridge_stop || echo "ab: 'cookiesync bridge stop' failed during teardown — the bridge may still be live" >&2
  }
  on_bridge_sig() {
    trap - EXIT INT TERM
    on_bridge_exit
    exit "$1"
  }
  trap on_bridge_exit EXIT
  trap 'on_bridge_sig 130' INT
  trap 'on_bridge_sig 143' TERM

  # Connect only when there is no live pairing: reconnecting a live one would reset the
  # page (mirrors the Browserbase path). A reconnect after a dropped daemon re-reads the
  # endpoint from a fresh `bridge open`, which reuses the running bridge by capability.
  if ! daemon_has_session; then
    resp="$(cookiesync bridge open --json ${bridge_target[@]+"${bridge_target[@]}"})" || {
      echo "ab: 'cookiesync bridge open' failed" >&2
      exit 1
    }
    bridge_armed=1 # bridge is live; a failure before hand-off must stop it, not leak it
    url="$(jq -r '.url // ""' <<<"$resp")"
    [[ -n "$url" ]] || {
      echo "ab: cookiesync bridge returned no ws url" >&2
      exit 1
    }
    # A loopback bridge url attaches via AGENT_BROWSER_CDP, never `connect` (which
    # relaunches a cookieless browser on loopback); the probe establishes the session,
    # run's exec reuses it (no env, like the daemon_has_session path above).
    AGENT_BROWSER_CDP="$url" agent-browser --session "$SLUG" title >/dev/null 2>&1 || {
      echo "ab: could not attach to the cookiesync bridge" >&2
      exit 1
    }
    bridge_armed=0 # handed off cleanly; exec below persists the bridge for reuse
  fi
  run
fi

if [[ "$force_local" == 1 || -z "$API_KEY" ]]; then
  [[ "$force_local" == 1 ]] || echo "ab: Browserbase key unavailable; using local browser." >&2
  run
fi

# curl with the API key fed via a stdin config so it never appears in argv. Bounded so
# a hung endpoint cannot stall a command, close, or the signal handler indefinitely.
api() { # api METHOD PATH [JSON-BODY] [no-retry]
  local retry=(--retry 2 --retry-max-time 30 --retry-connrefused)
  [[ "${4:-}" == no-retry ]] && retry=() # session creation has no idempotency key — never retry it
  if [[ -n "${3:-}" ]]; then
    curl -fsS --connect-timeout 5 --max-time 30 ${retry[@]+"${retry[@]}"} --config - -X "$1" "$BB_API$2" \
      -H 'Content-Type: application/json' -d "$3" <<<"header = \"X-BB-API-Key: ${API_KEY}\""
  else
    curl -fsS --connect-timeout 5 --max-time 30 ${retry[@]+"${retry[@]}"} --config - "$BB_API$2" \
      <<<"header = \"X-BB-API-Key: ${API_KEY}\""
  fi
}

tag_query() { jq -rn --arg s "user_metadata['ab']:'${SLUG}'" '$s | @uri'; } # URI-encoded tag filter

find_session() { # -> RUNNING session id tagged with this caller, or empty
  local resp
  resp="$(api GET "/sessions?status=RUNNING&q=$(tag_query)" 2>/dev/null)" || {
    echo "ab: Browserbase API unreachable" >&2
    exit 1
  }
  jq -r 'if type=="array" then (.[0].id // "") else "" end' <<<"$resp"
}

list_sessions() { # -> newline-separated RUNNING session ids tagged with this caller
  local resp
  resp="$(api GET "/sessions?status=RUNNING&q=$(tag_query)" 2>/dev/null)" || return 1
  jq -r 'if type=="array" then .[].id else empty end' <<<"$resp"
}

connect_url() { api GET "/sessions/$1" 2>/dev/null | jq -r '.connectUrl // ""'; } # id -> connectUrl

create_session() { # -> "id<TAB>connectUrl"
  local resp id url
  resp="$(api POST "/sessions" "$(jq -nc --arg t "$SLUG" --argjson to "$SESSION_TIMEOUT" \
    '{keepAlive: true, timeout: $to, userMetadata: {ab: $t}}')" no-retry)"
  id="$(jq -r '.id // ""' <<<"$resp")"
  url="$(jq -r '.connectUrl // ""' <<<"$resp")"
  # Residual window: a signal between the create POST returning and this single printf can leak
  # the session; it is bounded to one printf, and SESSION_TIMEOUT self-expiry is the backstop.
  [[ -z "$id" ]] || printf '%s' "$id" >"$created_marker" # arm the release before the id is printed
  printf '%s\t%s' "$id" "$url"
}

release() { api POST "/sessions/$1" '{"status":"REQUEST_RELEASE"}' >/dev/null 2>&1; }

sid="$(find_session)" || exit 1

if [[ "$is_close" == 1 ]]; then
  agent-browser --session "$SLUG" close >/dev/null 2>&1 || true
  # Reap every tagged RUNNING session, not just the first. Bounded retries make close
  # idempotent and resumable: a re-run finishes after an interrupt, and a transient GET
  # failure retries rather than assuming the tag is already clear.
  found=1
  for _ in 1 2 3 4 5; do
    ids="$(list_sessions)" || { found=1; continue; } # GET failed — retry, don't assume empty
    found=0
    while IFS= read -r id; do
      [[ -n "$id" ]] || continue
      found=1
      release "$id" || true
    done <<<"$ids"
    [[ "$found" == 0 ]] && break
  done
  [[ "$found" == 0 ]] || {
    echo "ab: some Browserbase sessions did not release — they will self-expire after ${SESSION_TIMEOUT}s" >&2
    exit 1
  }
  exit 0
fi

# Release a session THIS run created if we fail before handing off. exec (a successful
# hand-off) replaces the shell, so the EXIT trap never fires on success — the session
# persists for reuse, as intended. INT/TERM must exit after releasing so execution can
# never continue against a just-released session; the handler clears the EXIT trap so
# the release POSTs exactly once, and exits with the signal-correct code.
created_sid=""
# The marker file is written inside the create subshell (a shell var set there is invisible
# to the parent), so a kill landing between a successful create POST and the parent arming
# created_sid still releases the just-created session. Both channels are deduped on cleanup.
created_marker="$(mktemp)"
# Snapshot-and-clear so a second signal arriving during an in-flight release re-enters
# to empty state and cannot post a duplicate release.
on_exit() {
  local s="$created_sid" m=""
  created_sid=""
  if [[ -f "$created_marker" ]]; then
    m="$(cat "$created_marker" 2>/dev/null || true)"
    rm -f "$created_marker" 2>/dev/null || true
  fi
  [[ -z "$s" ]] || release "$s" || true
  [[ -z "$m" || "$m" == "$s" ]] || release "$m" || true
}
on_sig() { # on_sig EXIT-CODE (128+signal)
  trap - EXIT INT TERM
  on_exit
  exit "$1"
}
trap on_exit EXIT
trap 'on_sig 130' INT
trap 'on_sig 143' TERM

# Connect only when there is no live pairing: a fresh/dead Browserbase session gets
# created; a live one whose local daemon dropped gets reconnected. Reusing a live pairing
# must NOT reconnect — that would reset the page to about:blank.
if [[ -z "$sid" ]]; then
  IFS=$'\t' read -r sid url < <(create_session)
  [[ -n "$sid" ]] && created_sid="$sid" # arm the release before anything else can fail
  : >"$created_marker"                   # created_sid now owns the release; drop the marker copy
  if [[ -z "$url" ]]; then
    if [[ -n "$sid" ]]; then
      # The POST created a session (id present, marker armed) but returned no usable connectUrl.
      # Keep created_sid armed so the EXIT/signal trap releases this known id deterministically,
      # and fail loud rather than abandon a known-created session to self-expire.
      echo "ab: Browserbase session created but has no usable connect url" >&2
      exit 1
    fi
    # No id: the POST created nothing. Browserbase has no idempotency key and create runs without
    # --retry, so rather than risk a duplicate we adopt an already-running tagged session if one exists.
    sid="$(find_session)" || exit 1
    created_sid="" # adopted, not created — leave it to self-expire or a later close
    [[ -n "$sid" ]] || {
      echo "ab: could not create a Browserbase session" >&2
      exit 1
    }
    url="$(connect_url "$sid")"
    [[ -n "$url" ]] || {
      echo "ab: Browserbase session has no connect url" >&2
      exit 1
    }
  fi
  agent-browser --session "$SLUG" connect "$url" >/dev/null 2>&1 || {
    echo "ab: could not connect to the Browserbase session" >&2
    exit 1
  }
elif ! daemon_has_session; then
  url="$(connect_url "$sid")"
  [[ -n "$url" ]] || {
    echo "ab: Browserbase session has no connect url" >&2
    exit 1
  }
  agent-browser --session "$SLUG" connect "$url" >/dev/null 2>&1 || {
    echo "ab: could not reconnect to the Browserbase session" >&2
    exit 1
  }
fi

created_sid="" # handed off cleanly; disarm so exec does not release the live session
rm -f "$created_marker" 2>/dev/null || true # exec skips the EXIT trap — drop the marker here
run
