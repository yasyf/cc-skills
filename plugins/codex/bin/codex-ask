#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""codex-ask — the one way this plugin runs codex.

Prints REPLY_FILE:/LOG_FILE:/AWAIT: lines BEFORE codex starts, then launches
the pinned ``codex exec`` in a detached worker so a Bash-tool timeout kill can't
destroy finished work; the parent blocks on a status file and exits with codex's
code (log tail on failure). Every run lands under a fixed base
(``$CODEX_ASK_RUNS_DIR`` or ``${XDG_CACHE_HOME:-~/.cache}/codex-ask/runs``), so
``--ps`` can discover and any session can ``--await``/``--collect`` a dead
caller's runs. Recover a killed call with
``codex-ask --await <scratch-dir|reply-file>``.

usage: codex-ask [-m sol|luna] [-s ABS_DIR] [--image] [--schema FILE]
                 [--skip-git-repo-check] [QUESTION_FILE | - | QUESTION_TEXT]
       codex-ask --await <scratch-dir|reply-file>
       codex-ask --collect <root|lane>
       codex-ask --mint-root [LANE ...]
       codex-ask --ps
"""

import collections
import json
import os
import shlex
import shutil
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from pathlib import Path

# Always auth via the ChatGPT-plan OAuth login: the ambient OPENAI_API_KEY is
# billing-capped, and API-key auth never mounts the hosted image_gen tool.
os.environ.pop("OPENAI_API_KEY", None)

SELF = Path(__file__).resolve()
PLUGIN_ROOT = SELF.parent.parent

MODEL_SOL = "gpt-5.6-sol"
MODEL_LUNA = "gpt-5.6-luna"
EFFORT = "xhigh"

TERMINAL = ("completed", "failed", "no-run")
PRUNE_AGE_S = 7 * 24 * 3600
# --ps prunes only codex-ask's own minted dirs, never a caller-named fan-out lane.
RUN_PREFIXES = ("codex-ask.", "codex-root.")

USAGE = (
    "usage: codex-ask [-m sol|luna] [-s ABS_DIR] [--image] [--schema FILE] "
    "[--skip-git-repo-check] [QUESTION_FILE | - | QUESTION_TEXT]"
)

TURN_STARTED = '"type":"turn.started"'
TURN_COMPLETED = '"type":"turn.completed"'
TURN_FAILED = '"type":"turn.failed"'


def die(msg: str, code: int) -> None:
    print(msg, file=sys.stderr)
    sys.exit(code)


def usage() -> None:
    die(USAGE, 2)


def runs_base() -> Path:
    # The fixed registry root: every run (ad-hoc and --mint-root) lands here, so
    # the filesystem is the registry and --ps/--collect can find a dead caller's
    # runs. $CODEX_ASK_RUNS_DIR overrides for tests, but must clear the same
    # guards as -s — a relative or in-repo value would let --ps prune rmtree
    # arbitrary source dirs.
    override = os.environ.get("CODEX_ASK_RUNS_DIR")
    if override:
        if not override.startswith("/"):
            die("codex-ask: CODEX_ASK_RUNS_DIR must be an absolute path", 2)
        reject_outside_scratch(override, "CODEX_ASK_RUNS_DIR")
        base = Path(override)
    else:
        xdg = os.environ.get("XDG_CACHE_HOME") or str(Path.home() / ".cache")
        base = Path(xdg) / "codex-ask" / "runs"
    base.mkdir(parents=True, exist_ok=True)
    return base


def mint_scratch(prefix: str) -> str:
    return tempfile.mkdtemp(prefix=prefix + ".", dir=runs_base())


def tmp_sibling(path: Path) -> Path:
    return path.with_name(path.name + ".tmp")


def atomic_write(path: Path, text: str) -> None:
    # A unique per-writer temp file: two concurrent writers (e.g. two --await
    # recoveries synthesizing status) must not race on a shared "<name>.tmp".
    fd, tmp = tempfile.mkstemp(dir=path.parent, prefix=path.name + ".", suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(text)
        os.replace(tmp, path)
    except BaseException:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def read_pid(pid_file: Path) -> int | None:
    try:
        s = pid_file.read_text().strip()
    except OSError:
        return None
    return int(s) if s.isdigit() else None


def kill0(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


# proc_lstart: the process start-time via a fixed binary and pinned env, so a
# TZ or locale change between the launch record and a later probe can't reformat
# the timestamp and make a live lane read dead (/etc/localtime does change).
def proc_lstart(pid: int) -> str:
    env = {**os.environ, "TZ": "UTC", "LC_ALL": "C"}
    try:
        proc = subprocess.run(
            ["/bin/ps", "-o", "lstart=", "-p", str(pid)], capture_output=True, text=True, env=env
        )
    except OSError:
        return ""
    return proc.stdout.strip() if proc.returncode == 0 else ""


# pid_alive: kill-0 AND the recorded process start-time still matches, so a
# recycled pid (some unrelated process now holding the old number) reads dead.
# A blank/missing recorded lstart (a failed initial ps, or a legacy bash run with
# no lstart file still in flight at upgrade) degrades to bare kill-0.
def pid_alive(sdir: Path) -> bool:
    pid = read_pid(sdir / "pid")
    if pid is None or not kill0(pid):
        return False
    try:
        recorded = (sdir / "lstart").read_text().strip()
    except OSError:
        recorded = ""
    if not recorded:
        return True
    return proc_lstart(pid) == recorded


def first_line(path: Path) -> str:
    try:
        with path.open(errors="replace") as f:
            return f.readline().rstrip("\n")
    except OSError:
        return ""


def meta_lines(meta: Path) -> list[str]:
    try:
        return meta.read_text().splitlines()
    except OSError:
        return []


def grep(path: Path, needle: str) -> bool:
    try:
        with path.open(errors="replace") as f:
            return any(needle in line for line in f)
    except OSError:
        return False


def turn_started(log: str) -> bool:
    return bool(log) and Path(log).is_file() and grep(Path(log), TURN_STARTED)


def has_completed_marker(log: str) -> bool:
    return bool(log) and Path(log).is_file() and grep(Path(log), TURN_COMPLETED)


def nonempty(path: str) -> bool:
    return bool(path) and Path(path).exists() and Path(path).stat().st_size > 0


def tail(path: Path, n: int) -> None:
    # Bounded: keep only the last n lines in memory, never slurp a huge log.
    try:
        with path.open(errors="replace") as f:
            lines = collections.deque(f, maxlen=n)
    except OSError:
        return
    for line in lines:
        print(line.rstrip("\n"))


def json_escape(s: str) -> str:
    s = (
        s.replace("\\", "\\\\")
        .replace('"', '\\"')
        .replace("\t", "\\t")
        .replace("\r", "\\r")
        .replace("\n", "\\n")
    )
    # Strip the remaining raw C0 controls the JSONL can't carry (tab/cr/nl are
    # already escaped away above).
    return "".join(c for c in s if ord(c) >= 0x20)


# poll_status: block until <sdir>/status exists AND is non-empty (a concurrent
# -s reuse may rm/recreate it). Liveness is probed via the recorded pid: while
# the pid is absent wait generously (~15s) for the worker to register it; only a
# recorded-then-dead pid with no status is a genuine mid-flight death.
def poll_status(sdir: Path) -> None:
    status = sdir / "status"
    pid_file = sdir / "pid"
    meta = sdir / "meta"
    wait_pid = 0
    grace = 0
    while not nonempty(str(status)):
        if not pid_file.exists():
            wait_pid += 1
            if wait_pid >= 60:
                die(f"codex-ask: run at {sdir} never registered a pid", 1)
        elif pid_alive(sdir):
            grace = 0
        else:
            grace += 1
            if grace >= 4:
                # Dead pid + no status: killed after the staged-reply mv, before
                # the status write. meta line 1 = reply path; non-empty =>
                # complete, so synthesize a durable status=0 (later --await
                # replays it) and recover.
                lines = meta_lines(meta)
                r = lines[0] if lines else ""
                if nonempty(r):
                    # Another concurrent --await may publish status first; tolerate
                    # it (the loop re-reads and exits either way).
                    try:
                        atomic_write(status, "0\n")
                    except OSError:
                        pass
                    continue
                die(f"codex-ask: run at {sdir} exited without recording status", 1)
        time.sleep(0.25)


# report_status: tail the log on failure, exit codex's code. A 0 exit with an
# empty/missing reply is a silent codex death (exit 1); an empty/non-numeric
# status vanished mid-read (concurrent -s reuse) — fail cleanly.
def report_status(st: str, rfile: Path, lfile: Path) -> None:
    st = st.strip()
    if not st.isdigit():
        die("codex-ask: status went away before it could be read (concurrent -s reuse?)", 1)
    code = int(st)
    if code == 0 and not nonempty(str(rfile)):
        print("codex-ask: codex exited 0 but wrote no reply", file=sys.stderr)
        tail(lfile, 20)
        sys.exit(1)
    # Belt over the exit code: codex's --json emits turn.completed iff the turn
    # finished cleanly. A turn that started but lacks it died mid-turn.
    if code == 0 and turn_started(str(lfile)) and not has_completed_marker(str(lfile)):
        if grep(lfile, TURN_FAILED):
            print("codex-ask: codex reported turn.failed (see log tail)", file=sys.stderr)
        else:
            print(
                "codex-ask: codex died mid-turn (no turn.completed) — the working tree may "
                "hold partial, unverified edits; inspect with git/jj status before re-running",
                file=sys.stderr,
            )
        tail(lfile, 20)
        sys.exit(1)
    if code != 0:
        tail(lfile, 20)
    sys.exit(code)


def read_status(sdir: Path) -> str:
    try:
        return (sdir / "status").read_text()
    except OSError:
        return ""


@dataclass
class LaneInfo:
    state: str
    reply: str
    log: str
    reply_size: int
    excerpt: str
    qcount: int
    pid: int | None
    info: dict


# classify: derive one run dir's state from disk alone — the shared truth for
# --collect and --ps. Read-only; never blocks or inlines reply contents.
# classify: derive a run dir's state from disk, retried once so a concurrent
# unlink (worker staging/renaming, another session's prune) can't traceback
# --collect/--ps; a dir that vanishes entirely reads no-run.
def classify(d: Path) -> LaneInfo:
    try:
        return _classify(d)
    except OSError:
        try:
            return _classify(d)
        except OSError:
            return LaneInfo("no-run", "", "", 0, "", 0, None, {})


def _classify(d: Path) -> LaneInfo:
    r = log = excerpt = ""
    qcount = 0
    for qf in d.glob("codex-q-*"):
        if not qf.name.endswith(".log"):
            qcount += 1
    meta = d / "meta"
    has_meta = meta.is_file()
    info: dict = {}
    if has_meta:
        lines = meta_lines(meta)
        r = lines[0] if len(lines) > 0 else ""
        log = lines[1] if len(lines) > 1 else ""
        if len(lines) > 2:
            try:
                info = json.loads(lines[2])
            except json.JSONDecodeError:
                info = {}
        q = log[:-4] if log.endswith(".log") else ""
        if q and Path(q).is_file():
            excerpt = first_line(Path(q))
    reply_size = Path(r).stat().st_size if nonempty(r) else 0
    pid_file = d / "pid"
    pid = read_pid(pid_file) if pid_file.is_file() else None
    alive = pid_file.is_file() and pid_alive(d)
    status = d / "status"
    st = status.read_text().strip() if nonempty(str(status)) else ""

    if not has_meta:
        state = "no-run"
    elif st:
        if st == "0":
            if not nonempty(r):
                state = "failed"
            elif turn_started(log) and not has_completed_marker(log):
                state = "died"
            else:
                state = "completed"
        else:
            state = "failed"
    elif not pid_file.is_file():
        state = "pending"
    elif alive:
        state = "running"
    elif nonempty(r) and (not turn_started(log) or has_completed_marker(log)):
        state = "completed"
    else:
        state = "died"

    # Stale-.tmp sweep: a SIGKILLed worker can't run its finally, so a finished
    # run may leave an orphaned "<reply>.tmp". Reap it once the run is no longer
    # in flight (a running/pending lane's .tmp may be mid-write).
    if r and state not in ("running", "pending"):
        try:
            Path(r + ".tmp").unlink(missing_ok=True)
        except OSError:
            pass
    return LaneInfo(state, r, log, reply_size, excerpt, qcount, pid, info)


# collect_lane: print one JSONL record for a lane from its classified state.
def collect_lane(d: Path, lane: str) -> None:
    li = classify(d)
    await_cmd = ""
    if li.state not in TERMINAL:
        await_cmd = f"{shlex.quote(str(SELF))} --await {shlex.quote(str(d))}"
    record = (
        f'{{"lane":"{json_escape(lane)}","state":"{li.state}",'
        f'"reply_file":"{json_escape(li.reply)}","reply_size":{li.reply_size},'
        f'"log_file":"{json_escape(li.log)}","question":"{json_escape(li.excerpt)}",'
        f'"question_files":{li.qcount}'
    )
    if await_cmd:
        record += f',"await":"{json_escape(await_cmd)}"'
    record += "}"
    print(record)


def run_mtime(d: Path) -> float:
    newest = 0.0
    for name in ("status", "meta", "pid"):
        try:
            newest = max(newest, (d / name).stat().st_mtime)
        except OSError:
            pass
    if newest == 0.0:
        try:
            newest = d.stat().st_mtime
        except OSError:
            newest = time.time()
    return newest


def git_toplevel() -> str:
    try:
        proc = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True
        )
    except OSError:
        return ""
    return proc.stdout.strip() if proc.returncode == 0 else ""


def reject_outside_scratch(path: str, flag: str) -> None:
    top = git_toplevel()
    if top and (path + "/").startswith(top.rstrip("/") + "/"):
        die(f"codex-ask: {flag} must be outside the repository at {top} (lanes are never minted in-repo)", 2)
    home = os.environ.get("HOME", "")
    if home and (path + "/").startswith(home.rstrip("/") + "/.claude/"):
        die(f"codex-ask: {flag} must be outside ~/.claude (config dir, not scratch space)", 2)


def await_mode(target: str) -> None:
    if not target.startswith("/"):
        die("codex-ask: --await needs an absolute scratch dir or reply-file path", 2)
    tp = Path(target)
    sdir = tp if tp.is_dir() else tp.parent
    if not (sdir / "meta").is_file():
        die(f"codex-ask: no recorded codex-ask run at {sdir}", 2)
    lines = meta_lines(sdir / "meta")
    r = lines[0] if len(lines) > 0 else ""
    log = lines[1] if len(lines) > 1 else ""
    poll_status(sdir)
    # Generation re-check: a concurrent reuse may have wiped and rewritten meta
    # mid-await. Reporting this run's status against the previous generation's
    # reply/log would mix generations — refuse and say so instead.
    after = meta_lines(sdir / "meta")
    r2 = after[0] if len(after) > 0 else ""
    log2 = after[1] if len(after) > 1 else ""
    if (r2, log2) != (r, log):
        die(f"codex-ask: lane {sdir} was reused during --await (generation changed); re-run --await", 1)
    print(f"REPLY_FILE: {r}")
    print(f"LOG_FILE: {log}")
    report_status(read_status(sdir), Path(r), Path(log))


def collect_mode(root: str) -> None:
    if not root.startswith("/"):
        die("codex-ask: --collect needs an absolute lane-root or lane dir", 2)
    reject_outside_scratch(root, "--collect root")
    rootp = Path(root)
    if not rootp.is_dir():
        die(f"codex-ask: --collect: no such directory: {root}", 2)
    if (rootp / "meta").is_file() or (rootp / "status").is_file() or (rootp / "pid").is_file():
        collect_lane(rootp, ".")
    else:
        for d in sorted(rootp.iterdir()):
            if d.is_dir():
                collect_lane(d, d.name)
    sys.exit(0)


# ps_mode: the registry view. Walk the base, classify every run as one JSONL
# record, expand fan-out containers into their lane children, and reap only
# codex-ask's own terminal-and-aged run dirs (never a live lane, a container, or
# a caller-named lane).
def ps_mode() -> None:
    base = runs_base()
    now = time.time()
    for d in sorted(base.iterdir()):
        if d.is_dir():
            _ps_walk(d, now)
    sys.exit(0)


def _ps_walk(d: Path, now: float) -> None:
    has_run_state = any((d / f).exists() for f in ("meta", "status", "pid"))
    if not has_run_state:
        # A fan-out container holds lane subdirs and no run state of its own:
        # classify its children as lanes, never the container itself (and never
        # prune it — no meta means it can't satisfy the prune guard).
        try:
            subdirs = [c for c in sorted(d.iterdir()) if c.is_dir()]
        except OSError:
            subdirs = []
        if subdirs:
            for c in subdirs:
                _ps_walk(c, now)
            return
    li = classify(d)
    # Prune-and-skip before emitting so --ps is a post-prune snapshot: only a
    # codex-ask-minted dir with meta that classifies terminal and is past the age,
    # reclassified once more right before rmtree to close the classify->delete
    # TOCTOU (a reuse mid-walk flips it non-terminal and spares it). Caller-named
    # lanes and no-meta containers never match.
    if (
        d.name.startswith(RUN_PREFIXES)
        and (d / "meta").is_file()
        and li.state in TERMINAL
        and now - run_mtime(d) > PRUNE_AGE_S
        and classify(d).state in TERMINAL
    ):
        shutil.rmtree(d, ignore_errors=True)
        return
    log_age = None
    if li.log and Path(li.log).exists():
        try:
            log_age = round(now - Path(li.log).stat().st_mtime, 1)
        except OSError:
            log_age = None
    print(json.dumps({
        "dir": str(d),
        "state": li.state,
        "pid": li.pid,
        "started": li.info.get("ts"),
        "log_age_s": log_age,
        "cwd": li.info.get("cwd"),
        "session": li.info.get("session"),
        "reply_file": li.reply or None,
    }))


def mint_root_mode(lanes: list[str]) -> None:
    for lane in lanes:
        if not lane or lane[0] in ".-" or "/" in lane or "\n" in lane:
            die(
                "codex-ask: --mint-root lanes must be plain path segments "
                f"(no /, newlines, empty, or leading . or -): {lane}",
                2,
            )
    # Case-insensitive dedup: case-insensitive filesystems collapse review/Review
    # into one lane dir.
    seen: set[str] = set()
    dups: list[str] = []
    for lane in lanes:
        key = lane.lower()
        if key in seen:
            if lane not in dups:
                dups.append(lane)
        else:
            seen.add(key)
    if dups:
        die(f"codex-ask: --mint-root got duplicate lane names: {' '.join(dups)}", 2)
    root = Path(mint_scratch("codex-root"))
    for lane in lanes:
        try:
            (root / lane).mkdir(parents=True, exist_ok=True)
        except OSError:
            shutil.rmtree(root, ignore_errors=True)
            sys.exit(1)
    # All-or-nothing: nothing prints until the whole roster exists.
    print(f"ROOT: {root}")
    for lane in lanes:
        print(f"LANE: {root / lane}")
    sys.exit(0)


# run_worker: the detached side. Runs the pinned codex exec from the cmd file,
# stages the reply (rename only on rc 0 + non-empty), and writes codex's code to
# status. The whole lifecycle is wrapped: a spawn/exec error yields 126 (127 for
# not-found), a signal death normalizes to 128+signal, and any exception still
# lands a durable status with the .tmp swept — so no failure mode leaves the run
# statusless (which would hang a waiter). The pid/lstart files are written by the
# parent (see detach_worker), not here.
def run_worker(sdir: Path) -> None:
    reply_tmp = None
    rc = 126
    try:
        cmd = json.loads((sdir / "cmd").read_text())
        argv = cmd["argv"]
        question = Path(cmd["question"])
        reply = Path(cmd["reply"])
        reply_tmp = Path(cmd["reply_tmp"])
        log = Path(cmd["log"])
        try:
            with question.open("rb") as qin, log.open("wb") as logf:
                rc = subprocess.run(argv, stdin=qin, stdout=logf, stderr=logf).returncode
            if rc < 0:
                rc = 128 - rc  # signal death: -SIGTERM(-15) -> 143, -SIGKILL(-9) -> 137
        except FileNotFoundError:
            rc = 127
        if rc == 0 and nonempty(str(reply_tmp)):
            os.replace(reply_tmp, reply)
    except BaseException:
        pass  # rc stays 126 (or 127 from a not-found); status still lands below
    finally:
        if reply_tmp is not None:
            try:
                reply_tmp.unlink(missing_ok=True)  # no-op if it was renamed to reply
            except OSError:
                pass
        try:
            atomic_write(sdir / "status", f"{rc}\n")
        except OSError:
            pass


# detach_worker: double-fork so the worker is orphaned to PID 1 (escapes a
# ps-walked descendant kill) and setsid'd into its own session (escapes the
# process-group SIGTERM/SIGKILL), mirroring the old ``( set -m; … & )`` trick.
# The middle child forks the grandchild worker, pipes its pid back to the parent,
# and exits at once (orphaning it); the PARENT records pid+lstart (closing the
# window where meta exists but no pid ever appears) and reaps the middle child.
# A detach/re-exec failure lands a durable status 126 rather than hanging.
def detach_worker(sdir: Path) -> None:
    r, w = os.pipe()
    pid = os.fork()
    if pid > 0:
        os.close(w)
        os.waitpid(pid, 0)
        try:
            raw = os.read(r, 64)
        except OSError:
            raw = b""
        os.close(r)
        s = raw.decode(errors="replace").strip()
        gpid = int(s) if s.isdigit() else 0
        if gpid <= 0:
            atomic_write(sdir / "status", "126\n")
            return
        atomic_write(sdir / "lstart", proc_lstart(gpid) + "\n")
        atomic_write(sdir / "pid", f"{gpid}\n")
        return
    # middle child
    os.close(r)
    try:
        os.setsid()
        gpid = os.fork()
    except BaseException:
        os._exit(127)  # detach failed -> parent sees no gpid -> status 126
    if gpid > 0:
        try:
            os.write(w, f"{gpid}\n".encode())
        finally:
            os._exit(0)
    # grandchild = worker
    os.close(w)
    try:
        devnull = os.open(os.devnull, os.O_RDWR)
        os.dup2(devnull, 0)
        os.dup2(devnull, 1)
        os.dup2(devnull, 2)
        if devnull > 2:
            os.close(devnull)
        os.execv(sys.executable, [sys.executable, str(SELF), "--worker", str(sdir)])
    except BaseException:
        try:
            atomic_write(sdir / "status", "126\n")
        except OSError:
            pass
        os._exit(126)


def ask_mode(args: list[str]) -> None:
    model = MODEL_SOL
    scratch = ""
    extra_flags: list[str] = []
    rest: list[str] = []
    i, n = 0, len(args)
    while i < n:
        a = args[i]
        nxt = args[i + 1] if i + 1 < n else ""
        if a in ("-m", "--model"):
            if nxt == "sol":
                model = MODEL_SOL
            elif nxt == "luna":
                model = MODEL_LUNA
            else:
                die("codex-ask: -m takes sol or luna", 2)
            i += 2
        elif a in ("-s", "--scratch"):
            if not nxt.startswith("/"):
                die("codex-ask: --scratch must be an absolute path (never repo-relative)", 2)
            scratch = nxt
            i += 2
        elif a == "--image":
            extra_flags += ["--disable", "shell_tool"]
            i += 1
        elif a == "--schema":
            # --schema FILE → codex --output-schema: constrain the final reply to
            # a JSON Schema. Opt-in, for short verdict lanes only.
            if not (nxt and os.access(nxt, os.R_OK)):
                die("codex-ask: --schema needs a readable JSON Schema file", 2)
            extra_flags += ["--output-schema", nxt]
            i += 2
        elif a == "--skip-git-repo-check":
            extra_flags += ["--skip-git-repo-check"]
            i += 1
        elif a in ("-h", "--help"):
            print(USAGE)
            sys.exit(0)
        elif a == "--":
            rest = args[i + 1:]
            break
        elif a == "-":
            rest = args[i:]
            break
        elif a.startswith("-"):
            usage()
        else:
            rest = args[i:]
            break
    if len(rest) > 1:
        usage()

    # Read the question up front so an empty one refuses before anything is minted
    # (the fixed runs base would otherwise keep an empty codex-ask.XXXX as litter).
    if not rest or rest[0] == "-":
        question_bytes = sys.stdin.buffer.read()
    elif Path(rest[0]).is_file():
        question_bytes = Path(rest[0]).read_bytes()
    elif rest[0]:
        question_bytes = (rest[0] + "\n").encode()
    else:
        question_bytes = b""
    if not question_bytes:
        die("codex-ask: empty question", 2)

    if scratch:
        reject_outside_scratch(scratch, "--scratch")
        try:
            Path(scratch).mkdir(parents=True, exist_ok=True)
        except OSError:
            sys.exit(2)
        sdir = Path(scratch)
        # Refuse to clobber a still-alive run in this lane; a finished lane (its
        # status is written) stays reusable for a redo. Also refuse a lane whose
        # meta is <5s old even before a pid registers — that is the window where a
        # concurrent launcher wrote meta but its worker hasn't checked in yet, and
        # wiping it would clobber that in-flight run.
        meta_p = sdir / "meta"
        if meta_p.is_file() and not nonempty(str(sdir / "status")):
            try:
                recent = (time.time() - meta_p.stat().st_mtime) < 5
            except OSError:
                recent = False
            if pid_alive(sdir) or recent:
                die(f"codex-ask: lane {sdir} busy; --await it or mint a new lane", 1)
    else:
        sdir = Path(mint_scratch("codex-ask"))

    qfd, qpath = tempfile.mkstemp(prefix="codex-q-", dir=sdir)
    os.close(qfd)
    rfd, rpath = tempfile.mkstemp(prefix="codex-r-", dir=sdir)
    os.close(rfd)
    question = Path(qpath)
    reply = Path(rpath)
    log = Path(str(question) + ".log")
    question.write_bytes(question_bytes)

    # The developer_instructions feed carries the browser rules and the
    # ccx/MCP-off directive; running without it launches Chrome on the desktop.
    dev = (PLUGIN_ROOT / "AGENTS.md").read_text().rstrip("\n")

    reply_tmp = tmp_sibling(reply)
    argv = [
        "codex", "exec",
        "-c", f"model={model}",
        "-c", f"model_reasoning_effort={EFFORT}",
        "-c", "service_tier=fast",
        # No MCP mounts in a lane: an 18-run A/B showed zero correctness gain and
        # real overhead, and lanes wedge mid-ccx-MCP-call.
        "-c", "mcp_servers={}",
        "-c", f"developer_instructions={dev}",
        "-o", str(reply_tmp),
        "--json", "--color", "never",
        "--sandbox", "danger-full-access",
        *extra_flags,
    ]

    # A reused -s dir must never serve a previous run's state. Wiping meta too
    # establishes "meta present => describes the latest launch attempt".
    for stale in ("status", "pid", "lstart", "meta", "cmd"):
        (sdir / stale).unlink(missing_ok=True)
    cmd = {
        "argv": argv,
        "question": str(question),
        "reply": str(reply),
        "reply_tmp": str(reply_tmp),
        "log": str(log),
    }
    (sdir / "cmd").write_text(json.dumps(cmd))
    info = {"ts": time.time(), "cwd": os.getcwd(), "model": model}
    sid = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if sid:
        info["session"] = sid
    try:
        atomic_write(sdir / "meta", f"{reply}\n{log}\n{json.dumps(info)}\n")
    except OSError:
        die(f"codex-ask: {sdir} is in use by a concurrent run; pass a unique -s dir or omit it", 1)

    # Print recovery paths BEFORE codex starts: a killed Bash call still leaves
    # the --await recipe in the returned partial stdout. Only AWAIT is
    # shell-quoted so a spaced -s path stays copy-pasteable.
    print(f"REPLY_FILE: {reply}")
    print(f"LOG_FILE: {log}")
    print(f"AWAIT: {shlex.quote(str(SELF))} --await {shlex.quote(str(sdir))}")
    sys.stdout.flush()

    detach_worker(sdir)
    poll_status(sdir)
    report_status(read_status(sdir), reply, log)


def main() -> None:
    args = sys.argv[1:]
    match args:
        case ["--worker", sdir]:
            run_worker(Path(sdir))
        case ["--await", *rest]:
            await_mode(rest[0] if rest else "")
        case ["--collect", *rest]:
            collect_mode(rest[0] if rest else "")
        case ["--mint-root", *lanes]:
            mint_root_mode(lanes)
        case ["--ps"]:
            ps_mode()
        case _:
            ask_mode(args)


if __name__ == "__main__":
    main()
